#!/usr/bin/env bash
set -euo pipefail

# Run Laravel artisan inside the php83-fpm container where pdo_sqlsrv is installed.
CONTAINER=php83-fpm
PROJECT_DIR=/var/www/pesupeluh

if ! sudo docker ps --format '{{.Names}}' | grep -q "^${CONTAINER}$"; then
  echo "Container ${CONTAINER} is not running. Start it with:"
  echo "  sudo docker run -d --name ${CONTAINER} -v ${PROJECT_DIR}:${PROJECT_DIR} -p 127.0.0.1:9000:9000 pesupeluh/php:8.3-sqlsrv"
  exit 1
fi

sudo docker exec ${CONTAINER} php ${PROJECT_DIR}/artisan "$@"
